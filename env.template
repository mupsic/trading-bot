# ============================================
# TRADING BOT - API KEYS & CONFIGURATION
# ============================================
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env en la raíz del proyecto
# 2. Completa con tus API keys reales
# 3. NUNCA compartas este archivo ni lo subas a Git
# 4. Asegúrate de agregar .env a .gitignore
#
# ============================================

# ALPACA API (Trading Execution)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_TRADING=true

# FINNHUB API (Market Data & News) - FREE TIER
# Regístrate en: https://finnhub.io/register
# FREE tier: 250 API calls/min, 100,000 calls/mes
FINNHUB_API_KEY=your_finnhub_api_key_here

# TELEGRAM BOT (Mobile Notifications)
# Bot ya configurado, solo necesitas los tokens
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# BOT CONFIGURATION
BOT_NAME=TradingBot-ES
BOT_TIMEZONE=Europe/Madrid
BOT_MAX_POSITIONS=5
BOT_MAX_POSITION_SIZE=0.20
BOT_TRADES_PER_WEEK=3
BOT_TRAILING_STOP=0.10
BOT_HARD_STOP_LOSS=-0.07

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=logs/trading-bot.log

# NOTES:
# - Claude WebSearch: NATIVE (no API key needed)
# - Claude está integrado en las routines de Claude Code
# - Las búsquedas de mercado usan Finnhub (datos reales)
# - Las búsquedas generales usan WebSearch de Claude (análisis contextual)
