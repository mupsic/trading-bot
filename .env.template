# ============================================
# TRADING BOT - API KEYS & CONFIGURATION
# ============================================
#
# IMPORTANTE:
# - Renombra este archivo a .env cuando agregues tus claves reales
# - Nunca compartas este archivo ni subas a Git
# - Guarda este archivo en la raíz del proyecto
#
# ============================================

# ALPACA API (Trading Execution)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_TRADING=true

# NEWSAPI (Financial News & Market Research)
NEWSAPI_API_KEY=your_newsapi_api_key_here

# CLICKUP API (Notifications & Logging) - OPTIONAL
CLICKUP_API_TOKEN=your_clickup_api_token_here
CLICKUP_WORKSPACE_ID=your_workspace_id_here
CLICKUP_CHAT_ID=your_chat_id_here

# TELEGRAM BOT (Mobile Notifications) - RECOMMENDED
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# BOT CONFIGURATION
BOT_NAME=TradingBot-ES
BOT_TIMEZONE=Europe/Madrid
BOT_MAX_POSITIONS=5
BOT_MAX_POSITION_SIZE=0.20
BOT_TRADES_PER_WEEK=3
BOT_TRAILING_STOP=0.10
BOT_HARD_STOP_LOSS=-0.07

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=logs/trading-bot.log
